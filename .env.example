# ====================================================================
# APP
# ====================================================================
NODE_ENV=development
PORT=5000
APP_NAME=Spark
APP_VERSION=1.0.0
APP_URL=http://localhost:5000

# ====================================================================
# CLIENT URLS
# ====================================================================
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ====================================================================
# MONGODB
# ====================================================================
MONGODB_URI=mongodb://localhost:27017/spark_db

# ====================================================================
# REDIS
# ====================================================================
REDIS_URL=redis://localhost:6379

# ====================================================================
# JWT
# ====================================================================
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=change_this_to_another_secure_random_string
JWT_REFRESH_EXPIRE=30d

# ====================================================================
# FEATURE FLAGS (true or false)
# ====================================================================
BREVO=true
CLOUDINARY=true
FIREBASE=true
HDM_AI=true

# ====================================================================
# BREVO — SMS + Email
# ====================================================================
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@spark.hdm.com
BREVO_SENDER_NAME=Spark
BREVO_SMS_SENDER=Spark

# ====================================================================
# CLOUDINARY — Media Storage
# ====================================================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=spark
CLOUDINARY_MAX_FILE_SIZE=2097152000

# ====================================================================
# FIREBASE — Push Notifications
# ====================================================================
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_X509_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_X509_CERT_URL=your_cert_url

# ====================================================================
# HDM AI
# ====================================================================
HDM_AI_URL=https://hdmai-server.onrender.com/api/v1
HDM_AI_KEY=hdm_spa_3b1a00923453b5c6c25d30e9c20a1df2df4300f8d7a19b78

# ====================================================================
# ENCRYPTION (E2E)
# ====================================================================
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_LENGTH=32

# ====================================================================
# WEBSOCKET
# ====================================================================
WS_PING_INTERVAL=25000
WS_PING_TIMEOUT=20000

# ====================================================================
# OTP (SMS via Brevo)
# ====================================================================
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_MAX_ATTEMPTS=3

# ====================================================================
# RATE LIMITING
# ====================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5

# ====================================================================
# FILE UPLOAD
# ====================================================================
MAX_FILE_SIZE=2097152000
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/mpeg,video/quicktime
ALLOWED_DOC_TYPES=application/pdf,application/msword,text/plain,application/zip

# ====================================================================
# BACKUP
# ====================================================================
BACKUP_RETENTION_DAYS=90
BACKUP_MAX_SIZE_MB=2048
BACKUP_ENCRYPTION_ENABLED=true

# ====================================================================
# STATUS
# ====================================================================
STATUS_EXPIRE_HOURS=24
STATUS_MAX_VIDEO_DURATION=60
STATUS_MAX_IMAGES=10

# ====================================================================
# GROUP
# ====================================================================
GROUP_MAX_MEMBERS=1024
GROUP_MAX_ADMINS=10
GROUP_MAX_PINNED_MESSAGES=5

# ====================================================================
# MESSAGE
# ====================================================================
MESSAGE_EDIT_WINDOW_MINUTES=15
MESSAGE_DELETE_FOR_EVERYONE_WINDOW_HOURS=1
MESSAGE_MAX_FORWARD_COUNT=5

# ====================================================================
# SESSION
# ====================================================================
SESSION_MAX_DEVICES=5
SESSION_IDLE_TIMEOUT_DAYS=30

# ====================================================================
# PAYMENT — HDM Verified Blue Tick
# ====================================================================
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_PASSKEY=your_mpesa_passkey
MPESA_SHORTCODE=174379
MPESA_RECEIVE_PHONE=0712345678
MPESA_PAYBILL_NUMBER=247247
MPESA_TILL_NUMBER=123456

# ====================================================================
# PLANS (HDM Verified Blue Tick)
# ====================================================================
PLAN_MONTHLY_PRICE=4.99
PLAN_YEARLY_PRICE=39.99
PLAN_PERMANENT_PRICE=99.99
PLAN_CURRENCY=USD

# ====================================================================
# ADMIN
# ====================================================================
ADMIN_DEFAULT_EMAIL=admin@spark.hdm.com
ADMIN_DEFAULT_PASSWORD=change_this_immediately
SUPER_ADMIN_EMAIL=davismcintyre5@gmail.com

# ====================================================================
# LOGGING
# ====================================================================
LOG_LEVEL=debug
LOG_FILE_PATH=logs/spark.log

# ====================================================================
# CORS
# ====================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001